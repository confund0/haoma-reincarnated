<?xml version="1.0" encoding="utf-8"?>
<!--
    Calculator-themed launcher foreground. The disguise demands a calc icon
    on the home screen — anything else would tip the cover.

    Adaptive-icon viewport is 108×108 dp with a 66 dp guaranteed-visible
    safe zone in the centre (the outer ring gets cropped to circle / squircle
    / rounded-square depending on the launcher). Everything load-bearing
    stays inside x∈[21,87], y∈[21,87].
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Calculator body (rounded rect) -->
    <path
        android:pathData="M34,26 L74,26 A4,4 0 0 1 78,30 L78,82 A4,4 0 0 1 74,86 L34,86 A4,4 0 0 1 30,82 L30,30 A4,4 0 0 1 34,26 Z"
        android:fillColor="#F5F5F5"/>

    <!-- Display strip -->
