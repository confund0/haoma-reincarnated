        android:pathData="M36,32 L72,32 A2,2 0 0 1 74,34 L74,42 A2,2 0 0 1 72,44 L36,44 A2,2 0 0 1 34,42 L34,34 A2,2 0 0 1 36,32 Z"
        android:fillColor="#374151"/>

    <!-- Display digits (right-aligned, faint) -->
    <path
        android:pathData="M62,36 L62,40 M66,36 L66,40 M70,36 L70,40"
        android:strokeColor="#F59E0B"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"/>

    <!-- Button grid: 4 columns × 4 rows. Bottom-right "=" is the
